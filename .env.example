# QuestDB — OHLC source of truth (Docker host port 47900)
QUESTDB_HOST=localhost
QUESTDB_PORT=47900
QUESTDB_TABLE=ohlc_5m
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
USE_QUESTDB=true

# Redis — host port 47179 (see docs/docker.md)
REDIS_URL=redis://localhost:47179/0
USE_REDIS=true
REDIS_TTL_SECONDS=86400

# PostgreSQL — host port 47132
DATABASE_URL=postgresql://odin:odin@localhost:47132/odin
USE_POSTGRES=true

# ODIN defaults
DEFAULT_SYMBOL=NIFTY
DEFAULT_TIMEFRAME=5m
GATEWAY_TIMEOUT_SECONDS=60

# StrykeX integration — host port 47100
USE_ODIN=true
ODIN_API_URL=http://localhost:47100
