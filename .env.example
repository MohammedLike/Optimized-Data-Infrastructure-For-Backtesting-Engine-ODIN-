# QuestDB
QUESTDB_HOST=localhost
QUESTDB_PORT=9000
QUESTDB_TABLE=ohlc_5m
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
USE_QUESTDB=false

# Redis
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true
REDIS_TTL_SECONDS=86400

# PostgreSQL (ODIN persistent store)
DATABASE_URL=postgresql://odin:odin@localhost:5434/odin
USE_POSTGRES=false

# QuestDB
DEFAULT_SYMBOL=NIFTY
DEFAULT_TIMEFRAME=5m
GATEWAY_TIMEOUT_SECONDS=60

# StrykeX integration
USE_ODIN=true
ODIN_API_URL=http://localhost:8000
